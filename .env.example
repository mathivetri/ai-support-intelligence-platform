# ─────────────────────────────────────────────────────────────────────────
# .env.example — backend configuration template
#
# Copy this file to `.env` and fill in real values:
#     cp .env.example .env        (macOS / Linux)
#     Copy-Item .env.example .env (Windows PowerShell)
#
# `.env` is git-ignored and must never be committed. Only this template is.
# Every variable below maps to a field in backend/app/core/config.py.
# ─────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────
# ENVIRONMENT: development | staging | production
ENVIRONMENT=development
# DEBUG must be False in production (enforced by the config guard).
DEBUG=False

# ── Database ─────────────────────────────────────────────────────────────
# Async SQLAlchemy URL. Must use the postgresql+asyncpg driver.
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_support_platform

# Connection pool tuning (optional — sensible defaults if omitted).
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ── Security / JWT ───────────────────────────────────────────────────────
# Generate a strong 64-char secret (min length 32 enforced):
#     python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_generate_a_real_64_char_hex_secret_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production this must NOT contain localhost / 127.0.0.1 (config guard).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── AI provider (Groq via OpenAI-compatible client) ──────────────────────
# Get a key at https://console.groq.com/keys — keep it secret.
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=512
